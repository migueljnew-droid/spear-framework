{
  "$schema": "https://raw.githubusercontent.com/migueljnew-droid/spear-framework/main/schemas/config.schema.json",
  "version": "1.0.0",
  "project": {
    "name": "",
    "language": "auto",
    "description": ""
  },
  "phases": {
    "spec": {
      "enabled": true,
      "require_approval": true,
      "fuzz": {
        "enabled": true,
        "use_cross_validators": true,
        "block_on": "BLOCKER",
        "min_fuzz_score": 70
      }
    },
    "plan": { "enabled": true, "require_approval": true },
    "execute": {
      "enabled": true,
      "require_approval": false,
      "guardian": {
        "enabled": true,
        "provider": "gemini",
        "model": "gemini-2.5-flash",
        "categories": ["security", "architecture"],
        "stop_on": "CRITICAL",
        "warn_on": "HIGH",
        "max_tokens": 2000
      }
    },
    "audit": { "enabled": true, "require_approval": false },
    "ratchet": { "enabled": true, "require_approval": false }
  },
  "audit": {
    "categories": {
      "security": { "enabled": true, "block_on": "CRITICAL" },
      "dependencies": { "enabled": true, "block_on": "CRITICAL" },
      "performance": { "enabled": true, "block_on": "HIGH" },
      "code_quality": { "enabled": true, "block_on": "HIGH" },
      "documentation": { "enabled": true, "block_on": "CRITICAL" },
      "architecture": { "enabled": true, "block_on": "HIGH" }
    },
    "parallel": true,
    "auto_fix": false,
    "ensemble": {
      "enabled": false,
      "mode": "per-category",
      "providers": [
        { "provider": "gemini" },
        { "provider": "kimi" }
      ],
      "merge_strategy": "union",
      "min_agreement": 1,
      "include_code_context": true,
      "max_context_lines": 500
    },
    "cross_validators": [
      {
        "name": "gemini",
        "enabled": true,
        "provider": "gemini",
        "model": "gemini-2.5-flash",
        "categories": ["security", "performance", "architecture"],
        "mode": "delta",
        "orchestration": "swarm",
        "temperature": 0.2,
        "max_review_files": 40,
        "block_on_disagreement": "CRITICAL"
      }
    ],
    "consensus": {
      "enabled": true,
      "min_agreement_for_dismiss": 2,
      "escalate_on_unanimous_new": true
    },
    "self_healing": {
      "enabled": true,
      "severities": ["LOW", "MEDIUM"],
      "categories": ["code_quality", "documentation"],
      "never_heal": ["security"],
      "max_files_per_fix": 3,
      "require_re_audit": true
    },
    "hermetic": {
      "enabled": true,
      "golden_ratio_threshold": 1.618,
      "min_hermetic_score": 50,
      "block_on": "HIGH"
    }
  },
  "ratchet": {
    "auto_tighten": true,
    "tighten_buffer_percent": 2,
    "improvement_threshold_percent": 5,
    "require_justification_to_loosen": true
  },
  "hooks": {
    "pre-commit": true,
    "commit-msg": true,
    "secrets-scan": true,
    "lint-check": true,
    "fitness-check": true,
    "dependency-audit": true,
    "doc-coverage": true,
    "test-gate": true
  },
  "memory": {
    "backend": "json",
    "auto_index": true,
    "max_entries_per_category": 500
  },
  "adapter": "auto"
}
